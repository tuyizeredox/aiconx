{
  "name": "Story",
  "type": "object",
  "properties": {
    "author_username": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_avatar": {
      "type": "string"
    },
    "media_url": {
      "type": "string",
      "description": "Image or video URL"
    },
    "media_type": {
      "type": "string",
      "enum": [
        "image",
        "video",
        "text"
      ],
      "default": "image"
    },
    "caption": {
      "type": "string"
    },
    "bg_color": {
      "type": "string",
      "default": "#6366f1"
    },
    "views_count": {
      "type": "number",
      "default": 0
    },
    "expires_at": {
      "type": "string",
      "description": "ISO timestamp, 24h after creation"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "author_username",
    "media_type"
  ]
}